# EditorConfig helps maintain consistent coding styles
# https://EditorConfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
max_line_length = off
trim_trailing_whitespace = false

[*.{json,yaml,yml}]
indent_size = 2
indent_style = space

[*.{py,pyw}]
indent_size = 4
indent_style = space
max_line_length = 100

[*.{ts,tsx,js,jsx}]
indent_size = 2
indent_style = space
max_line_length = 100

[*.css,*.scss]
indent_size = 2
indent_style = space

[*.sql]
indent_size = 2
indent_style = space
