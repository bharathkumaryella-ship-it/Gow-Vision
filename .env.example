# ============================================
# GowVision Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# FLASK CONFIGURATION
# ============================================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-characters

# ============================================
# CORS CONFIGURATION
# ============================================
# Allowed origins for frontend to access the API
# For development: http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# For Docker: http://gowvision-frontend:3000
# For production: https://your-frontend-domain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ============================================
# DATABASE
# ============================================
DATABASE_URL=sqlite:///gowvision.db
# For PostgreSQL: postgresql://user:password@localhost:5432/gowvision

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production-min-32-characters
JWT_ACCESS_TOKEN_EXPIRES=2592000

# ============================================
# SECURITY
# ============================================
MAX_CONTENT_LENGTH=16777216
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,bmp
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_TIMEOUT=900

# ============================================
# API RATE LIMITING
# ============================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE_URL=memory
# For Redis: redis://localhost:6379

# ============================================
# MODEL CONFIGURATION
# ============================================
MODEL_PATH=models/trained_models/breed_classifier.tflite
LABELS_PATH=models/trained_models/class_labels.json

# ============================================
# LLM CONFIGURATION (OLLAMA)
# ============================================
OLLAMA_MODEL=qwen2:1.5b
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/gowvision.log