@startuml UseCase
!theme plain
left to right direction
skinparam shadowing false

actor Farmer as F
actor Admin as A

package GowConnect {
  usecase "Detect Cattle Breed" as UC1
  usecase "Analyze Health" as UC2
  usecase "Search Ear Tag" as UC3
  usecase "View Government Schemes" as UC4
  usecase "Manage Schemes" as UC5
  usecase "View Statistics" as UC6
  usecase "Process Image" as UC7
  usecase "Analyze Symptoms" as UC8

  F --> UC1
  F --> UC2
  F --> UC3
  F --> UC4
  A --> UC5
  A --> UC6
  
  UC1 --> UC7
  UC2 --> UC8
}

@enduml
